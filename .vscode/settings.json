{
  "editor.fontSize": 12,
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  
  // --- PERFORMANCE BOOSTERS ---
  "editor.minimap.enabled": false, // Saves RAM and GPU
  "editor.cursorBlinking": "solid", // Reduces CPU cycles for rendering
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.guides.indentation": false, // Less visual calculation
  "editor.renderWhitespace": "none",
  "editor.controlCharacters": false,
  "editor.selectionHighlight": false,
  "editor.occurrencesHighlight": "off",
  
  // --- ANGULAR EFFICIENCY ---
  "editor.formatOnSave": true, // Essential for fast dev
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "angular.enable-strict-mode-prompt": false,
  "nxConsole.generateAiAgentRules": true,

  // --- SYSTEM LIGHTNESS ---
  "workbench.iconTheme": "vscode-icons", // Use a simple icon set
  "workbench.startupEditor": "none",
  "explorer.confirmDelete": false,
  "files.autoSave": "onFocusChange",
  "git.autorefresh": false, // Manual git refresh saves background CPU
  "update.mode": "manual", // Prevent background update checks
  "telemetry.telemetryLevel": "off", // Stop background data sending
  
  // --- SEARCH OPTIMIZATION (Crucial for old SSDs) ---
  "search.followSymlinks": false,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true, // Stops VS Code from indexing huge folders
    "**/dist": true,
    "**/tmp": true
  },

  
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#b3e0f2",
    "activityBar.background": "#b3e0f2",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#e35cbc",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#b3e0f2",
    "statusBar.background": "#87ceeb",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#5bbce4",
    "statusBarItem.remoteBackground": "#87ceeb",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#87ceeb",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#87ceeb99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "skyblue"


} 